<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>Usuario</servlet-name>
        <servlet-class>Servelt.Usuario</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Rol</servlet-name>
        <servlet-class>Servelt.Rol</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Procedimiento</servlet-name>
        <servlet-class>Servelt.Procedimiento</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Sesion</servlet-name>
        <servlet-class>Servelt.Sesion</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Paciente</servlet-name>
        <servlet-class>Servelt.Paciente</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Proyeccion</servlet-name>
        <servlet-class>Servelt.Proyeccion</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Informe</servlet-name>
        <servlet-class>Servelt.Informe</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Usuario</servlet-name>
        <url-pattern>/Usuario</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Rol</servlet-name>
        <url-pattern>/Rol</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Procedimiento</servlet-name>
        <url-pattern>/Procedimiento</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Sesion</servlet-name>
        <url-pattern>/Sesion</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Paciente</servlet-name>
        <url-pattern>/Paciente</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Proyeccion</servlet-name>
        <url-pattern>/Proyeccion</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Informe</servlet-name>
        <url-pattern>/Informe</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
